[global]
    font = Iosevka 11
    frame_width = 3  # Широкая рамка
    corner_radius = 12  # Более скруглённые углы
    padding = 10  # Больше внутреннего отступа
    transparency = 5  # Меньшая прозрачность для более насыщенных цветов

    # Время отображения уведомлений
    timeout = 6

    # Форматирование уведомлений: заголовок сверху, а подробности ниже
    format = "<b>%s</b>\n%b"

    # Отступы для иконок убраны, так как параметр не поддерживается
    icon_position = left
    max_icon_size = 50

# Цветовая схема для уровней срочности
[urgency_low]
icon = /home/tetto/Downloads/jpg(1)
    background = "#292840"  # Темно-синий фон с оттенком фиолетового
    foreground = "#d1c4e9"  # Светло-фиолетовый текст
    frame_color = "#7c4dff"  # Неоново-фиолетовая рамка

[urgency_normal]
    background = "#2c274c"  # Яркий фиолетовый фон, немного светлее
    foreground = "#e1bee7"  # Светло-розовый текст
    frame_color = "#8e24aa"  # Ярко-фиолетовая неоновая рамка

[urgency_critical]
    background = "#ff4081"  # Ярко-розовый фон для критических уведомлений
    foreground = "#ffffff"  # Белый текст
    frame_color = "#e040fb"  # Насыщенно-фиолетовая рамка

